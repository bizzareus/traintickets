# Browser Use (availability checks)
BROWSER_USE_API_KEY=
BROWSER_USE_WEBHOOK_SECRET=

# Alerts
WHATSAPP_API_KEY=
CALL_API_KEY=

# Email (Resend) — used for user alerts and admin monitoring notifications
RESEND_API_KEY=
# Optional override; defaults to me@kartikarora.in
MONITORING_ADMIN_EMAIL=

# URLs
NEXT_PUBLIC_APP_URL=http://localhost:3010
API_URL=http://localhost:3009
FRONTEND_URL=http://localhost:3010

# Server
PORT=3009

# OpenAI — service2 seat planning (Responses API)
# Practical latency order: (1) smallest model that passes evals (2) fewer tokens (3) prompt caching when prompts repeat
# (4) streaming for time-to-first-token in UI — not wired here yet (5) lower reasoning + verbosity (6) predicted outputs — edit-style only
# OPENAI_API_KEY=
# Use the smallest model that passes your accuracy checks; upgrade only if needed
# OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=medium
OPENAI_MAX_OUTPUT_TOKENS=4096
# low|medium|high — or off|default to omit (API default). low reduces output tokens / latency when supported
OPENAI_TEXT_VERBOSITY=low
# Optional: default|auto|flex|priority|scale
# OPENAI_SERVICE_TIER=
# Optional: stable bucketing key so similar requests share prompt prefix cache hits (e.g. hashed user id)
# OPENAI_PROMPT_CACHE_KEY=
