generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  phone              String?
  passwordHash       String              @map("password_hash")
  createdAt          DateTime            @default(now()) @map("created_at")
  monitoringRequests MonitoringRequest[]
}

model Train {
  id                  String               @id @default(cuid())
  trainNumber         String               @unique @map("train_number")
  trainName           String               @map("train_name")
  originStation       String               @map("origin_station")
  destinationStation  String               @map("destination_station")
  departureTime       String?              @map("departure_time")
  arrivalTime         String?              @map("arrival_time")
  active              Boolean              @default(true)
  chartEventInstances ChartEventInstance[]
  monitoringRequests  MonitoringRequest[]
  chartRules          ChartRule[]
}

model ChartEventInstance {
  id                String             @id @default(cuid())
  trainId           String             @map("train_id")
  stationCode       String             @map("station_code")
  journeyDate       DateTime           @map("journey_date") @db.Date
  chartTimestamp    DateTime           @map("chart_timestamp")
  sequenceNumber    Int                @map("sequence_number")
  executed          Boolean            @default(false)
  executedAt        DateTime?          @map("executed_at")
  browserExecutions BrowserExecution[]
  train             Train              @relation(fields: [trainId], references: [id], onDelete: Cascade)

  @@index([chartTimestamp, executed])
  @@index([trainId, stationCode, journeyDate])
}

model ChartRule {
  id             String  @id @default(cuid())
  trainId        String  @map("train_id")
  stationCode    String  @map("station_code")
  chartTimeLocal String  @map("chart_time_local")
  sequenceNumber Int     @map("sequence_number")
  active         Boolean @default(true)
  train          Train   @relation(fields: [trainId], references: [id], onDelete: Cascade)
}

model MonitoringRequest {
  id                String                  @id @default(cuid())
  userId            String                  @map("user_id")
  trainId           String                  @map("train_id")
  stationCode       String                  @map("station_code")
  journeyDate       DateTime                @map("journey_date") @db.Date
  classCode         String                  @map("class_code")
  status            MonitoringRequestStatus @default(scheduled)
  createdAt         DateTime                @default(now()) @map("created_at")
  alertLogs         AlertLog[]
  browserExecutions BrowserExecution[]
  train             Train                   @relation(fields: [trainId], references: [id], onDelete: Cascade)
  user              User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([trainId, stationCode, journeyDate, status])
}

model BrowserExecution {
  id                   String                 @id @default(cuid())
  monitoringRequestId  String                 @map("monitoring_request_id")
  chartEventInstanceId String                 @map("chart_event_instance_id")
  jobId                String?                @map("job_id")
  type                 BrowserExecutionType   @default(availability)
  status               BrowserExecutionStatus @default(pending)
  resultPayload        Json?                  @map("result_payload")
  createdAt            DateTime               @default(now()) @map("created_at")
  completedAt          DateTime?              @map("completed_at")
  chartEventInstance   ChartEventInstance     @relation(fields: [chartEventInstanceId], references: [id], onDelete: Cascade)
  monitoringRequest    MonitoringRequest      @relation(fields: [monitoringRequestId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

model TrainList {
  id                     String  @id @default(cuid())
  trainNumber            String  @unique @map("train_number")
  label                  String
  chartTimeIngestionDone Boolean @default(false) @map("chart_time_ingestion_done")

  @@index([trainNumber])
  @@index([label])
  @@index([chartTimeIngestionDone])
}

model TrainScheduleCache {
  id          String   @id @default(cuid())
  trainNumber String   @unique @map("train_number")
  trainName   String   @map("train_name")
  stationFrom String   @map("station_from")
  stationTo   String   @map("station_to")
  stationList Json     @map("station_list")
  fetchedAt   DateTime @default(now()) @map("fetched_at")
  /// IRCTC schedule: trainRunsOnMon..Sun as "Y"|"N" (JSON object)
  trainRunsOn Json?    @map("train_runs_on")

  @@index([trainNumber])
}

model TrainStationChartTime {
  id                String   @id @default(cuid())
  trainNumber       String   @map("train_number")
  stationCode       String   @map("station_code")
  chartTimeLocal    String   @map("chart_time_local")
  createdAt         DateTime @default(now()) @map("created_at")
  chartTwoDayOffset Int?     @map("chart_two_day_offset")
  chartTwoTimeLocal String?  @map("chart_two_time_local")
  chartOneDayOffset      Int?     @map("chart_one_day_offset")
  chartRemoteStation     String?  @map("chart_remote_station")
  chartNextRemoteStation String?  @map("chart_next_remote_station")

  @@unique([trainNumber, stationCode])
  @@index([trainNumber])
  @@index([stationCode])
}

model MonitoringContact {
  id                        String                     @id @default(cuid())
  email                     String?                    @unique @db.VarChar(255)
  mobile                    String?                    @db.VarChar(20)
  createdAt                 DateTime                   @default(now()) @map("created_at")
  journeyMonitoringRequests JourneyMonitoringRequest[]

  @@index([email])
  @@index([mobile])
}

model JourneyMonitoringRequest {
  id                  String             @id @default(cuid())
  monitoringContactId String?            @map("monitoring_contact_id")
  trainNumber         String             @map("train_number")
  fromStationCode     String             @map("from_station_code")
  toStationCode       String             @map("to_station_code")
  journeyDate         DateTime           @map("journey_date") @db.Date
  classCode           String             @map("class_code")
  createdAt           DateTime           @default(now()) @map("created_at")
  monitoringContact   MonitoringContact? @relation(fields: [monitoringContactId], references: [id])

  @@index([monitoringContactId])
  @@index([trainNumber, journeyDate])
}

model JourneyMonitorContact {
  id               String   @id @default(cuid())
  journeyRequestId String   @unique @map("journey_request_id")
  email            String?  @db.VarChar(255)
  mobile           String?  @db.VarChar(20)
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([journeyRequestId])
  tasks            ChartTimeAvailabilityTask[]
}

model ChartTimeAvailabilityTask {
  id                 String    @id @default(cuid())
  journeyRequestId   String    @map("journey_request_id")
  trainNumber        String    @map("train_number")
  trainName          String?   @map("train_name")
  fromStationCode    String    @map("from_station_code")
  toStationCode      String    @map("to_station_code")
  stationCode        String    @map("station_code")
  journeyDate        DateTime  @map("journey_date") @db.Date
  classCode          String    @map("class_code")
  chartAt            DateTime  @map("chart_at")
  status             String    @default("pending")
  resultPayload      Json?     @map("result_payload")
  createdAt          DateTime  @default(now()) @map("created_at")
  completedAt        DateTime? @map("completed_at")
  emailNotifiedAt    DateTime? @map("email_notified_at")
  whatsappNotifiedAt DateTime? @map("whatsapp_notified_at")

  contact JourneyMonitorContact @relation(fields: [journeyRequestId], references: [journeyRequestId])

  @@index([chartAt, status])
  @@index([journeyRequestId])
}

model AvailabilityCheck {
  id            String    @id @default(cuid())
  jobId         String?   @unique @map("job_id")
  trainNumber   String    @map("train_number")
  stationCode   String    @map("station_code")
  classCode     String    @map("class_code")
  journeyDate   DateTime  @map("journey_date") @db.Date
  status        String    @default("pending")
  resultPayload Json?     @map("result_payload")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  @@index([jobId])
}

model AlertLog {
  id                  String            @id @default(cuid())
  monitoringRequestId String            @map("monitoring_request_id")
  channel             AlertChannel
  status              AlertLogStatus
  createdAt           DateTime          @default(now()) @map("created_at")
  monitoringRequest   MonitoringRequest @relation(fields: [monitoringRequestId], references: [id], onDelete: Cascade)

  @@index([monitoringRequestId])
}

model CacheEntry {
  key       String    @id
  value     Json
  expiresAt DateTime? @map("expires_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([expiresAt])
  @@map("cache_entry")
}

model StationCache {
  stationCode String   @id @map("station_code")
  stationName String   @map("station_name")
  metadata    Json
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([stationName])
  @@map("station_cache")
}

enum MonitoringRequestStatus {
  scheduled
  completed
  expired
}

enum BrowserExecutionType {
  availability
}

enum BrowserExecutionStatus {
  pending
  running
  success
  failed
}

enum AlertChannel {
  whatsapp
  call
  push
}

enum AlertLogStatus {
  sent
  failed
}
model RedditAnalyzedComment {
  id               String   @id @map("id")
  content          String   @map("content")
  author           String   @map("author")
  permalink        String   @map("permalink")
  trainNumber      String?  @map("train_number")
  origin           String?  @map("origin")
  destination      String?  @map("destination")
  pnr              String?  @map("pnr")
  dateOfTravel     String?  @map("date_of_travel")
  currentStatus    String?  @map("current_status")
  rawJson          Json?    @map("raw_json")
  screenshotUrl    String?  @map("screenshot_url")
  status           String   @default("PENDING") @map("status")
  createdAt        DateTime @default(now()) @map("created_at")
  analyzedAt       DateTime? @map("analyzed_at")

  @@index([trainNumber])
  @@index([pnr])
  @@map("reddit_analyzed_comments")
}
