{
  "name": "railchart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "next dev -p 3010",
    "dev:api": "cd backend && npm run start:dev",
    "build": "npm run build:api && next build",
    "build:web": "next build",
    "build:api": "cd backend && npm run build",
    "start": "concurrently -n api,web -c cyan,magenta \"npm run start:api\" \"npm run start:web\"",
    "start:web": "next start -p 3010",
    "start:api": "cd backend && npm run start:prod",
    "lint": "eslint .",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:seed": "cd backend && npm run db:seed",
    "db:studio": "cd backend && npm run db:studio",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@posthog/react": "^1.8.2",
    "@sentry/nextjs": "^10.47.0",
    "axios": "^1.7.0",
    "axios-retry": "^4.5.0",
    "browser-use-sdk": "^3.3.0",
    "clsx": "^2.1.1",
    "flowbite": "^4.0.1",
    "moment": "^2.30.1",
    "next": "^16.1.6",
    "openai": "^6.27.0",
    "posthog-js": "^1.364.1",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "concurrently": "^9.1.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "@playwright/test": "^1.55.0"
  }
}
