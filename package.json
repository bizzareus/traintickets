{
  "name": "railchart",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm run dev:api\" \"npm run dev:web\"",
    "dev:web": "next dev -p 3010",
    "dev:api": "cd backend && npm run start:dev",
    "build": "npm run build:api && next build",
    "build:api": "cd backend && npm run build",
    "start": "concurrently -n api,web -c cyan,magenta \"npm run start:api\" \"next start -p 3010\"",
    "start:api": "cd backend && npm run start:prod",
    "lint": "next lint",
    "db:migrate": "cd backend && npm run db:migrate",
    "db:seed": "cd backend && npm run db:seed",
    "db:studio": "cd backend && npm run db:studio"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
