# Frontend (Next.js) – use in .env.local
# API URL of the NestJS backend
NEXT_PUBLIC_API_URL=http://localhost:3009
NEXT_PUBLIC_APP_URL=http://localhost:3010
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# Sentry (optional) — browser SDK uses NEXT_PUBLIC_*; server/edge can use SENTRY_DSN or the public DSN
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=
# 0–1; default 0.2 in production, 1 in development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=
# Optional: upload source maps during `next build` (https://docs.sentry.io/platforms/javascript/guides/nextjs/)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=